.git
.gitignore
.gitattributes
.editorconfig
.DS_Store

# Never bake secrets into an image
.env
.env.*
!.env.example

# Reinstalled inside the image
node_modules
vendor

# Local logs (container creates its own)
storage/logs/*
!storage/logs/.gitignore

# Tests / docs not needed at runtime
tests
phpunit.xml
.phpunit.result.cache
pest.php
*.md
LICENSE

# Build metadata (avoid stale cache invalidation noise)
Dockerfile*
docker-compose*.yml
.dockerignore

npm-debug.log
yarn-error.log
